{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ScopeState",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "input_mode",
    "source_refs",
    "market_reference_required",
    "open_questions",
    "assumptions",
    "scope_status",
    "approved_by_user"
  ],
  "properties": {
    "input_mode": {
      "type": "string",
      "enum": ["market_replication", "interactive_discovery", "document_driven"]
    },
    "source_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "market_reference_required": { "type": "boolean" },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "scope_status": {
      "type": "string",
      "enum": ["drafting", "awaiting_user_validation", "approved"]
    },
    "approved_by_user": { "type": "boolean" }
  }
}

