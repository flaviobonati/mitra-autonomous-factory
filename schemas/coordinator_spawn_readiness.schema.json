{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mitra.factory/schemas/coordinator_spawn_readiness.schema.json",
  "title": "Coordinator Spawn Readiness",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "coordinator_code",
    "execution_code",
    "factory_control_project_dir",
    "factory_gateway_path",
    "product_workspace_id",
    "product_project_id",
    "product_project_dir",
    "product_frontend_dir",
    "product_backend_dir",
    "project_is_not_factory",
    "project_has_frontend_backend",
    "project_has_git",
    "project_has_mitra_agent_files",
    "runtime_contract_path",
    "coordinator_prompt_path",
    "coordinator_package_path",
    "tmux_session",
    "first_message_is_natural_user_request_only"
  ],
  "properties": {
    "coordinator_code": { "type": "string", "minLength": 1 },
    "execution_code": { "type": "string", "minLength": 1 },
    "factory_control_project_dir": { "type": "string", "minLength": 1 },
    "factory_gateway_path": { "type": "string", "minLength": 1 },
    "product_workspace_id": { "type": "string", "minLength": 1 },
    "product_project_id": { "type": "string", "not": { "const": "46955" } },
    "product_project_dir": { "type": "string", "minLength": 1 },
    "product_frontend_dir": { "type": "string", "minLength": 1 },
    "product_backend_dir": { "type": "string", "minLength": 1 },
    "project_is_not_factory": { "const": true },
    "project_has_frontend_backend": { "const": true },
    "project_has_git": { "const": true },
    "project_has_mitra_agent_files": { "const": true },
    "runtime_contract_path": { "type": "string", "minLength": 1 },
    "coordinator_prompt_path": { "type": "string", "minLength": 1 },
    "coordinator_package_path": { "type": "string", "minLength": 1 },
    "tmux_session": { "type": "string", "minLength": 1 },
    "first_message_is_natural_user_request_only": { "const": true }
  }
}
