{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DevHandoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "execution_id",
    "mission_id",
    "workspace_id",
    "project_id",
    "round_type",
    "deploy",
    "implemented_stories",
    "implemented_entities",
    "implemented_data_flows",
    "known_gaps",
    "known_risks",
    "requires_seed_actions",
    "test_accounts",
    "smoke_tests"
  ],
  "properties": {
    "execution_id": { "type": "string", "minLength": 1 },
    "mission_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "round_type": {
      "type": "string",
      "enum": ["R1", "RN"]
    },
    "deploy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deployed", "url"],
      "properties": {
        "deployed": { "type": "boolean" },
        "url": { "type": "string" },
        "bundle_hash": { "type": "string" },
        "deployed_at": { "type": "string", "format": "date-time" }
      }
    },
    "implemented_stories": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["story_id", "status"],
        "properties": {
          "story_id": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["implemented", "partial", "not_implemented", "blocked"]
          },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": { "type": "string" }
        }
      }
    },
    "implemented_entities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["entity_id", "list", "add", "edit", "delete"],
        "properties": {
          "entity_id": { "type": "string", "minLength": 1 },
          "list": { "type": "boolean" },
          "add": { "type": "boolean" },
          "edit": { "type": "boolean" },
          "delete": { "type": "boolean" },
          "notes": { "type": "string" }
        }
      }
    },
    "implemented_data_flows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["flow_id", "status"],
        "properties": {
          "flow_id": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["implemented", "partial", "not_implemented", "blocked"]
          },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": { "type": "string" }
        }
      }
    },
    "known_gaps": {
      "type": "array",
      "items": { "$ref": "#/$defs/gap" }
    },
    "known_risks": {
      "type": "array",
      "items": { "$ref": "#/$defs/risk" }
    },
    "requires_seed_actions": { "type": "boolean" },
    "test_accounts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["persona_id", "role", "login_hint"],
        "properties": {
          "persona_id": { "type": "string", "minLength": 1 },
          "role": { "type": "string" },
          "login_hint": { "type": "string" },
          "landing_route": { "type": "string" },
          "credential_note": { "type": "string" }
        }
      }
    },
    "smoke_tests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["test_id", "status", "evidence"],
        "properties": {
          "test_id": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "blocked"]
          },
          "evidence": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "gap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gap_id", "description", "severity"],
      "properties": {
        "gap_id": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "related_story_id": { "type": "string" },
        "related_flow_id": { "type": "string" }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["risk_id", "description", "severity"],
      "properties": {
        "risk_id": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        }
      }
    }
  }
}
