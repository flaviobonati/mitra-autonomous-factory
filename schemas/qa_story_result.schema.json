{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QAStoryResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "execution_id",
    "mission_id",
    "batch_id",
    "batch_range",
    "story_id",
    "story_title",
    "persona_id",
    "persona_name",
    "story_type",
    "priority",
    "expected_story_summary",
    "preconditions",
    "test_status",
    "story_accuracy_percent",
    "story_gap_percent",
    "ui_gap_percent",
    "data_gap_percent",
    "artifact_gap_percent",
    "expected_steps_count",
    "executed_steps_count",
    "step_results",
    "stopped_early",
    "stop_reason",
    "ui_evidence",
    "data_flow_evidence",
    "artifact_evidence",
    "bugs_found",
    "expected_vs_actual_summary",
    "verdict"
  ],
  "properties": {
    "execution_id": { "type": "string", "minLength": 1 },
    "mission_id": { "type": "string", "minLength": 1 },
    "batch_id": { "type": "string", "minLength": 1 },
    "batch_range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start_index", "end_index"],
      "properties": {
        "start_index": { "type": "integer", "minimum": 0 },
        "end_index": { "type": "integer", "minimum": 0 }
      }
    },
    "story_id": { "type": "string", "minLength": 1 },
    "story_title": { "type": "string" },
    "persona_id": { "type": "string", "minLength": 1 },
    "persona_name": { "type": "string" },
    "story_type": {
      "type": "string",
      "enum": ["implantation", "maintenance", "final_user", "supporting", "exception"]
    },
    "priority": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"]
    },
    "expected_story_summary": { "type": "string" },
    "preconditions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "test_status": {
      "type": "string",
      "enum": ["not_started", "in_progress", "passed", "failed", "blocked", "incomplete"]
    },
    "story_accuracy_percent": { "type": "number", "minimum": 0, "maximum": 100 },
    "story_gap_percent": { "type": "number", "minimum": 0, "maximum": 100 },
    "ui_gap_percent": { "type": "number", "minimum": 0, "maximum": 100 },
    "data_gap_percent": { "type": "number", "minimum": 0, "maximum": 100 },
    "artifact_gap_percent": { "type": "number", "minimum": 0, "maximum": 100 },
    "expected_steps_count": { "type": "integer", "minimum": 0 },
    "executed_steps_count": { "type": "integer", "minimum": 0 },
    "step_results": {
      "type": "array",
      "items": { "$ref": "#/$defs/step_result" }
    },
    "stopped_early": { "type": "boolean" },
    "stop_reason": { "type": "string" },
    "ui_evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence" }
    },
    "data_flow_evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence" }
    },
    "artifact_evidence": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence" }
    },
    "bugs_found": {
      "type": "array",
      "items": { "$ref": "#/$defs/bug" }
    },
    "expected_vs_actual_summary": { "type": "string" },
    "verdict": {
      "type": "string",
      "enum": ["passed", "failed", "blocked", "incomplete"]
    }
  },
  "$defs": {
    "step_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_index",
        "expected_action",
        "actual_action",
        "ui_expected",
        "ui_actual",
        "status"
      ],
      "properties": {
        "step_index": { "type": "integer", "minimum": 1 },
        "actor": { "type": "string" },
        "route_or_screen": { "type": "string" },
        "expected_action": { "type": "string" },
        "actual_action": { "type": "string" },
        "ui_expected": { "type": "string" },
        "ui_actual": { "type": "string" },
        "data_expected": { "type": "string" },
        "data_actual": { "type": "string" },
        "artifact_expected": { "type": "string" },
        "artifact_actual": { "type": "string" },
        "evidence_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "status": {
          "type": "string",
          "enum": ["passed", "failed", "blocked", "skipped"]
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "evidence_type", "summary"],
      "properties": {
        "evidence_id": { "type": "string", "minLength": 1 },
        "evidence_type": {
          "type": "string",
          "enum": ["screenshot", "dom_check", "query", "download", "artifact", "log", "note"]
        },
        "path": { "type": "string" },
        "query": { "type": "string" },
        "result": { "type": "string" },
        "summary": { "type": "string" }
      }
    },
    "bug": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bug_id", "severity", "description", "reproduction"],
      "properties": {
        "bug_id": { "type": "string", "minLength": 1 },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "description": { "type": "string" },
        "reproduction": { "type": "string" },
        "evidence_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
