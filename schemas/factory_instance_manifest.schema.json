{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mitra.factory/schemas/factory_instance_manifest.schema.json",
  "title": "Factory Instance Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "instance_code",
    "root_dir",
    "mitra",
    "factory_control_project",
    "product_project_defaults",
    "coordinator",
    "conversation_wrapper",
    "safety"
  ],
  "properties": {
    "instance_code": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{2,80}$"
    },
    "root_dir": {
      "type": "string",
      "minLength": 1
    },
    "mitra": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base_url", "integrations_url", "workspace_id", "token_env", "env_file"],
      "properties": {
        "base_url": { "type": "string", "minLength": 1 },
        "integrations_url": { "type": "string", "minLength": 1 },
        "workspace_id": { "type": "string", "pattern": "^[0-9]+$" },
        "token_env": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
        "env_file": { "type": "string", "minLength": 1 }
      }
    },
    "factory_control_project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_id", "project_dir", "gateway_path", "server_function"],
      "properties": {
        "project_id": { "type": "string", "pattern": "^[0-9]+$" },
        "project_dir": { "type": "string", "minLength": 1 },
        "gateway_path": { "type": "string", "minLength": 1 },
        "server_function": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "id_file", "setup_script"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "id": { "type": ["string", "number"] },
            "id_file": { "type": "string", "minLength": 1 },
            "setup_script": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "product_project_defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workspace_id", "name_prefix", "template_dir", "mitra_agent_dir"],
      "properties": {
        "workspace_id": { "type": "string", "pattern": "^[0-9]+$" },
        "name_prefix": { "type": "string", "minLength": 1 },
        "template_dir": { "type": "string", "minLength": 1 },
        "mitra_agent_dir": { "type": "string", "minLength": 1 }
      }
    },
    "coordinator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dir_root", "default_model", "session_runtime", "package_source_dir"],
      "properties": {
        "dir_root": { "type": "string", "minLength": 1 },
        "default_model": { "type": "string", "minLength": 1 },
        "session_runtime": { "enum": ["tmux"] },
        "package_source_dir": { "type": "string", "minLength": 1 }
      }
    },
    "conversation_wrapper": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "inbox_dir", "send_command", "token_env"],
      "properties": {
        "type": { "enum": ["telegram"] },
        "inbox_dir": { "type": "string", "minLength": 1 },
        "send_command": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "token_env": { "type": "string", "pattern": "^[A-Z0-9_]+$" },
        "webhook_url": { "type": "string" }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "forbidden_product_project_ids",
        "require_product_git",
        "require_coordinator_tmux",
        "require_agent_readiness",
        "allow_meta_agent_operational_events"
      ],
      "properties": {
        "forbidden_product_project_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[0-9]+$" }
        },
        "require_product_git": { "const": true },
        "require_coordinator_tmux": { "const": true },
        "require_agent_readiness": { "const": true },
        "allow_meta_agent_operational_events": { "const": false }
      }
    }
  }
}
