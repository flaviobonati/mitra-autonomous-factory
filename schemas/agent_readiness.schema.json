{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mitra.factory/schemas/agent_readiness.schema.json",
  "title": "Agent Readiness Proof",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_type",
    "mission_id",
    "read_files",
    "runtime_contract_loaded",
    "mission_loaded",
    "blocking_gaps"
  ],
  "properties": {
    "agent_type": { "type": "string", "minLength": 1 },
    "mission_id": { "type": "string", "minLength": 1 },
    "read_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "bytes"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "bytes": { "type": "integer", "minimum": 1 },
          "read_at": { "type": "string" }
        }
      }
    },
    "runtime_contract_loaded": { "type": "boolean" },
    "mission_loaded": { "type": "boolean" },
    "blocking_gaps": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
