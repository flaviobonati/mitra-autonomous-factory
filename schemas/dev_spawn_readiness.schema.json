{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mitra.factory/schemas/dev_spawn_readiness.schema.json",
  "title": "Dev Spawn Readiness",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "execution_id",
    "mission_id",
    "workspace_id",
    "project_id",
    "product_project_dir",
    "frontend_path",
    "backend_path",
    "git_head_before",
    "git_status_before",
    "dirty_tree_policy",
    "runtime_contract_path",
    "runtime_contract_hash",
    "dev_prompt_path",
    "dev_prompt_hash",
    "system_prompt_path",
    "system_prompt_hash",
    "agents_md_path",
    "agents_md_hash",
    "scope_artifact_refs",
    "dev_write_scope",
    "dev_forbidden_scope",
    "expected_model",
    "output_contract",
    "project_is_not_factory",
    "project_has_frontend_backend",
    "project_has_git",
    "project_has_mitra_agent_files",
    "prompt_readiness_required",
    "backend_mitra_required",
    "commit_or_block_required"
  ],
  "properties": {
    "execution_id": { "type": "string", "minLength": 1 },
    "mission_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "not": { "const": "46955" } },
    "product_project_dir": { "type": "string", "minLength": 1 },
    "frontend_path": { "type": "string", "minLength": 1 },
    "backend_path": { "type": "string", "minLength": 1 },
    "git_head_before": { "type": "string", "minLength": 7 },
    "git_status_before": { "type": "string" },
    "dirty_tree_policy": { "type": "string", "minLength": 1 },
    "runtime_contract_path": { "type": "string", "minLength": 1 },
    "runtime_contract_hash": { "type": "string", "minLength": 1 },
    "dev_prompt_path": { "type": "string", "minLength": 1 },
    "dev_prompt_hash": { "type": "string", "minLength": 1 },
    "system_prompt_path": { "type": "string", "minLength": 1 },
    "system_prompt_hash": { "type": "string", "minLength": 1 },
    "agents_md_path": { "type": "string", "minLength": 1 },
    "agents_md_hash": { "type": "string", "minLength": 1 },
    "scope_artifact_refs": { "type": "array", "minItems": 1 },
    "dev_write_scope": {
      "type": "array",
      "contains": { "const": "product_project_dir" }
    },
    "dev_forbidden_scope": {
      "type": "array",
      "contains": { "const": "factory_control_project_dir" }
    },
    "expected_model": { "type": "string", "const": "claude-opus-4-7" },
    "output_contract": { "type": "object" },
    "project_is_not_factory": { "type": "boolean", "const": true },
    "project_has_frontend_backend": { "type": "boolean", "const": true },
    "project_has_git": { "type": "boolean", "const": true },
    "project_has_mitra_agent_files": { "type": "boolean", "const": true },
    "prompt_readiness_required": { "type": "boolean", "const": true },
    "backend_mitra_required": { "type": "boolean", "const": true },
    "commit_or_block_required": { "type": "boolean", "const": true }
  }
}
