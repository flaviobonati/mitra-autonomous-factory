{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mitra.factory/schemas/v2/factory_occurrence.schema.json",
  "title": "Factory Occurrence v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "occurrence_code",
    "factory_instance_code",
    "workspace_id",
    "project_registry_id",
    "card_code",
    "status",
    "current_phase",
    "created_at",
    "updated_at",
    "source"
  ],
  "properties": {
    "schema_version": { "const": "factory.v2" },
    "occurrence_code": { "type": "string", "pattern": "^occ_[a-z0-9][a-z0-9_-]{4,120}$" },
    "factory_instance_code": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "pattern": "^[0-9]+$" },
    "project_registry_id": { "type": "string", "minLength": 1 },
    "card_code": { "type": "string", "pattern": "^card_[a-z0-9][a-z0-9_-]{4,120}$" },
    "title": { "type": "string" },
    "status": { "enum": ["open", "running", "blocked", "done", "archived"] },
    "current_phase": { "$ref": "#/$defs/phase" },
    "created_at": { "$ref": "#/$defs/iso_datetime" },
    "updated_at": { "$ref": "#/$defs/iso_datetime" },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "idempotency_key"],
      "properties": {
        "kind": { "enum": ["ui_add_project", "telegram", "cli_bootstrap", "migration", "simulation"] },
        "telegram_message_id": { "type": "string" },
        "idempotency_key": { "type": "string", "minLength": 8 }
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "phase": {
      "enum": [
        "Scope Discovery & Construction",
        "Development",
        "QA Horizontal",
        "Fix / Retest Horizontal",
        "QA Story Validation",
        "Fix / Retest Story",
        "QA Consolidation",
        "Release Review",
        "Production"
      ]
    },
    "iso_datetime": {
      "type": "string",
      "pattern": "^20[0-9]{2}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    }
  }
}
