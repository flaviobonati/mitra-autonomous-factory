{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mitra.factory/schemas/v2/next_mission_v2.schema.json",
  "title": "Next Mission v2",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "next_mission_id",
    "phase",
    "current_event",
    "allowed_actor",
    "target_agent",
    "required_model",
    "mission_type",
    "title",
    "mission_instruction",
    "next_goal",
    "next_event",
    "idempotency",
    "workdir_requirements",
    "required_prompt_paths",
    "input_artifacts",
    "required_outputs",
    "schemas_or_validators",
    "preflight_checks",
    "allowed_actions",
    "forbidden_actions",
    "success_criteria",
    "blocking_conditions",
    "quality_score"
  ],
  "properties": {
    "schema_version": { "const": "factory.v2" },
    "next_mission_id": { "type": "string", "pattern": "^nm_[a-z0-9][a-z0-9_-]{4,120}$" },
    "phase": { "$ref": "#/$defs/phase" },
    "current_event": { "type": "string", "minLength": 1 },
    "allowed_actor": { "type": "string", "minLength": 1 },
    "target_agent": { "type": "string", "minLength": 1 },
    "required_model": { "type": "string", "minLength": 1 },
    "mission_type": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "mission_instruction": { "type": "string", "minLength": 40 },
    "next_goal": { "type": "string", "minLength": 1 },
    "next_event": { "type": "string", "minLength": 1 },
    "idempotency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "key_rule"],
      "properties": {
        "required": { "const": true },
        "key_rule": { "type": "string", "minLength": 1 },
        "example_key": { "type": "string" }
      }
    },
    "workdir_requirements": {
      "type": "object",
      "required": ["required", "scope", "forbidden", "must_have"],
      "properties": {
        "required": { "const": true },
        "scope": { "type": "string", "minLength": 1 },
        "forbidden": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "must_have": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "required_prompt_paths": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "input_artifacts": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "required_outputs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "schemas_or_validators": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "preflight_checks": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "allowed_actions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "forbidden_actions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "success_criteria": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "blocking_conditions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "quality_score": {
      "type": "object",
      "additionalProperties": false,
      "required": ["simplicity_objectivity", "max_score", "failed_checks"],
      "properties": {
        "simplicity_objectivity": { "const": 10 },
        "max_score": { "const": 10 },
        "failed_checks": { "type": "array", "maxItems": 0 }
      }
    }
  },
  "$defs": {
    "phase": {
      "enum": [
        "Scope Discovery & Construction",
        "Development",
        "QA Horizontal",
        "Fix / Retest Horizontal",
        "QA Story Validation",
        "Fix / Retest Story",
        "QA Consolidation",
        "Release Review",
        "Production"
      ]
    }
  }
}
