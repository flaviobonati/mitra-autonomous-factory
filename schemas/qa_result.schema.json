{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QAResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "execution_id",
    "mission_id",
    "design_score",
    "ux_score",
    "adherence_score",
    "data_flow_score",
    "story_accuracy_percent",
    "gap_percent",
    "story_gaps",
    "ui_gaps",
    "data_gaps",
    "artifact_gaps",
    "approved",
    "horizontal_status",
    "story_batch_status",
    "missing_batches",
    "uncovered_stories",
    "failed_stories",
    "failed_flows",
    "bugs_found",
    "qa_core_checklist_execution"
  ],
  "properties": {
    "execution_id": { "type": "string", "minLength": 1 },
    "mission_id": { "type": "string", "minLength": 1 },
    "design_score": { "type": "number", "minimum": 0, "maximum": 10 },
    "ux_score": { "type": "number", "minimum": 0, "maximum": 10 },
    "adherence_score": { "type": "number", "minimum": 0, "maximum": 10 },
    "data_flow_score": { "type": "number", "minimum": 0, "maximum": 10 },
    "story_accuracy_percent": { "type": "number", "minimum": 0, "maximum": 100 },
    "gap_percent": { "type": "number", "minimum": 0, "maximum": 100 },
    "story_gaps": {
      "type": "array",
      "items": { "$ref": "#/$defs/gap" }
    },
    "ui_gaps": {
      "type": "array",
      "items": { "$ref": "#/$defs/gap" }
    },
    "data_gaps": {
      "type": "array",
      "items": { "$ref": "#/$defs/gap" }
    },
    "artifact_gaps": {
      "type": "array",
      "items": { "$ref": "#/$defs/gap" }
    },
    "approved": { "type": "boolean" },
    "horizontal_status": {
      "type": "string",
      "enum": ["not_run", "passed", "failed", "blocked", "incomplete"]
    },
    "story_batch_status": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["batch_id", "status"],
        "properties": {
          "batch_id": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["not_run", "passed", "failed", "blocked", "incomplete"]
          },
          "stories_total": { "type": "integer", "minimum": 0 },
          "stories_passed": { "type": "integer", "minimum": 0 },
          "stories_failed": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "missing_batches": {
      "type": "array",
      "items": { "type": "string" }
    },
    "uncovered_stories": {
      "type": "array",
      "items": { "type": "string" }
    },
    "failed_stories": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["story_id", "reason"],
        "properties": {
          "story_id": { "type": "string", "minLength": 1 },
          "reason": { "type": "string" },
          "batch_id": { "type": "string" }
        }
      }
    },
    "failed_flows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["flow_id", "reason"],
        "properties": {
          "flow_id": { "type": "string", "minLength": 1 },
          "reason": { "type": "string" },
          "related_story_id": { "type": "string" }
        }
      }
    },
    "bugs_found": {
      "type": "array",
      "items": { "$ref": "#/$defs/bug" }
    },
    "qa_core_checklist_execution": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/qa_core_check" }
    },
    "bug_retest_matrix": {
      "type": "array",
      "items": { "$ref": "#/$defs/bug_retest" }
    }
  },
  "$defs": {
    "qa_core_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "check_id",
        "dimension",
        "source_rule",
        "requirement",
        "status",
        "evidence"
      ],
      "properties": {
        "check_id": { "type": "string", "minLength": 1 },
        "dimension": {
          "type": "string",
          "enum": ["ui", "ux", "features", "data_flow", "rule", "dev_check"]
        },
        "source_rule": { "type": "string", "minLength": 1 },
        "requirement": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["PASS", "FAIL", "NA_WITH_REASON"]
        },
        "mandatory": { "type": "boolean" },
        "method": { "type": "string" },
        "actual": { "type": "string" },
        "evidence": { "type": "string", "minLength": 20 },
        "screenshot_path": { "type": "string" },
        "artifact_path": { "type": "string" },
        "query_or_command": { "type": "string" }
      }
    },
    "bug_retest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bug_id",
        "origin_report",
        "origin_failed_checks",
        "status",
        "evidence_by_check"
      ],
      "properties": {
        "bug_id": { "type": "string", "minLength": 1 },
        "origin_report": { "type": "string", "minLength": 1 },
        "origin_failed_checks": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "status": {
          "type": "string",
          "enum": ["PASS", "FAIL", "BLOCKED"]
        },
        "evidence_by_check": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/retest_evidence" }
        }
      }
    },
    "retest_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "method", "actual"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["PASS", "FAIL", "BLOCKED"]
        },
        "method": { "type": "string", "minLength": 1 },
        "actual": { "type": "string", "minLength": 20 },
        "screenshot_path": { "type": "string" },
        "artifact_path": { "type": "string" },
        "query_or_command": { "type": "string" }
      }
    },
    "gap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gap_id", "severity", "description"],
      "properties": {
        "gap_id": { "type": "string", "minLength": 1 },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "description": { "type": "string" },
        "related_story_id": { "type": "string" },
        "related_flow_id": { "type": "string" },
        "evidence": { "type": "string" }
      }
    },
    "bug": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bug_id", "severity", "description", "source_layer"],
      "properties": {
        "bug_id": { "type": "string", "minLength": 1 },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "description": { "type": "string" },
        "source_layer": {
          "type": "string",
          "enum": ["horizontal", "story", "consolidation"]
        },
        "reproduction": { "type": "string" },
        "evidence": { "type": "string" }
      }
    }
  }
}
